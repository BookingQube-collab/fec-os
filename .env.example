# Copy to .env.local and fill in values from Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Server-only
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

SUPABASE_PROJECT_ID=your-project-ref
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project-ref.supabase.co:5432/postgres
# IPv4-friendly session pooler (Supabase Dashboard → Connect) — use for migrations from Windows
SESSION_POOLER_DATABASE_URL=postgresql://postgres.your-project-ref:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Cron endpoints (/api/public/*) — generate with: openssl rand -hex 32
CRON_SECRET=

# External attendance ingest (POST /api/public/attendance-ingest) — see docs/api/attendance-ingest.md
ATTENDANCE_INGEST_API_KEY=

# Optional: email notification webhook placeholder
NOTIFICATION_EMAIL_WEBHOOK=
# Get a key from Lovable AI gateway or use OPENAI_API_KEY as fallback for checklist generation.
LOVABLE_API_KEY=
OPENAI_API_KEY=

# BookingQube revenue integration (see docs/BOOKINGQUBE.md)
BOOKINGQUBE_API_URL=
BOOKINGQUBE_API_KEY=
# BOOKINGQUBE_REVENUE_PATH=/revenue/daily
# BOOKINGQUBE_AUTH_STYLE=bearer
# BOOKINGQUBE_USE_MOCK=true
# Per-branch BookingQube store IDs (defaults to lowercase branch codes)
# BOOKINGQUBE_STORE_KDS_CC=
# BOOKINGQUBE_STORE_INF_CC=
# BOOKINGQUBE_STORE_UA_DM=
# BOOKINGQUBE_STORE_CB_VM=
# BOOKINGQUBE_STORE_CB_DSM=
# BOOKINGQUBE_STORE_CAR_AP=
